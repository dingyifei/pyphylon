# Annotation, MLST, and CD-HIT workflow
# Included by the master Snakefile — expects DATA, TEMP, SPECIES, config variables
#
# Rules: anno_get_db, anno_bakta, concat_faas, cdhit, mlst, mlst_report

import pandas as pd


def _get_anno_samples(wildcards=None):
    """Read genome list from the nb_2b checkpoint output (deferred until 2b completes)."""
    meta_path = checkpoints.nb_2b_checkpoint.get().output.metadata
    genomes = pd.read_csv(str(meta_path), dtype={"genome_id": str})
    return genomes["genome_id"].tolist()


rule anno_get_db:
    output:
        version=config["BAKTA_DB_DIR"] + "/version.json",
    params:
        db_dir=config["BAKTA_DB_DIR"],
        tmp_dir=TEMP,
        tarball="db-light.tar.xz" if config.get("BAKTA_DB_TYPE", "light") == "light" else "db.tar.xz",
        extract_name="db-light" if config.get("BAKTA_DB_TYPE", "light") == "light" else "db",
    conda:
        "../envs/bakta.yml"
    container:
        config["CONTAINER_BAKTA"]
    shell:
        "mkdir -p {params.db_dir} "
        "&& wget -O {params.tmp_dir}/{params.tarball} https://zenodo.org/records/14916843/files/{params.tarball} "
        "&& tar -xJf {params.tmp_dir}/{params.tarball} -C {params.tmp_dir} "
        "&& rm -rf {params.db_dir}/* "
        "&& mv {params.tmp_dir}/{params.extract_name}/* {params.db_dir}/ "
        "&& rm -rf {params.tmp_dir}/{params.extract_name} {params.tmp_dir}/{params.tarball} "
        "&& (amrfinder_update --force_update --database {params.db_dir}/amrfinderplus-db || true)"


rule anno_bakta:
    input:
        fna=f"{DATA}/raw/genomes/fna/{{sample}}.fna",
        db=config["BAKTA_DB_DIR"] + "/version.json",
    output:
        fna=f"{DATA}/processed/bakta/{{sample}}/{{sample}}.fna",
        gbff=f"{DATA}/processed/bakta/{{sample}}/{{sample}}.gbff",
        faa=f"{DATA}/processed/bakta/{{sample}}/{{sample}}.faa",
        tsv=f"{DATA}/processed/bakta/{{sample}}/{{sample}}.tsv",
    params:
        db_dir=config["BAKTA_DB_DIR"],
    conda:
        "../envs/bakta.yml"
    container:
        config["CONTAINER_BAKTA"]
    threads:
        config["BAKTA_THREADS"]
    shell:
        "bakta --db {params.db_dir} "
        "--output {DATA}/processed/bakta/{wildcards.sample} "
        "--locus-tag {wildcards.sample} --prefix {wildcards.sample} "
        "--threads {threads} --force {input.fna}"


rule concat_faas:
    input:
        lambda wc: expand(
            f"{DATA}/processed/bakta/{{sample}}/{{sample}}.faa",
            sample=_get_anno_samples(),
        )
    output:
        f"{TEMP}/{SPECIES}.faa"
    shell:
        "cat {input} > {output}"


rule cdhit:
    input:
        f"{TEMP}/{SPECIES}.faa"
    output:
        f"{DATA}/processed/cd-hit-results/{SPECIES}"
    conda:
        "../envs/cdhit.yml"
    container:
        config["CONTAINER_CDHIT"]
    threads:
        config["CDHIT_THREADS"]
    shell:
        "cd-hit -i {input} -o {output} -d 0 -n 5 -c 0.8 -M 0 -aL 0.8 -T {threads}"


rule mlst:
    input:
        f"{DATA}/raw/genomes/fna/{{sample}}.fna"
    output:
        f"{DATA}/processed/mlst/{{sample}}.tsv"
    conda:
        "../envs/mlst.yml"
    container:
        config["CONTAINER_MLST"]
    threads:
        config["MLST_THREADS"]
    shell:
        "mlst {input} > {output}"


rule mlst_report:
    input:
        files=lambda wc: expand(
            f"{DATA}/processed/mlst/{{sample}}.tsv",
            sample=_get_anno_samples(),
        )
    output:
        f"{DATA}/processed/mlst_report.txt"
    shell:
        "cat {input.files} > {output}"
