# Mash workflow: sketch all pangenome genomes and compute pairwise distances
# Included by the master Snakefile — expects DATA, TEMP, config variables

import os

def _get_mash_samples():
    """Discover genome .fna files from the raw genomes directory."""
    fna_dir = f"{DATA}/raw/genomes/fna"
    if not os.path.isdir(fna_dir):
        return []
    return glob_wildcards(f"{fna_dir}/{{sample}}.fna").sample


rule pangenome_mash:
    input:
        lambda wc: expand(f"{DATA}/raw/genomes/fna/{{sample}}.fna", sample=_get_mash_samples())
    output:
        mash_sketch=f"{TEMP}/2b_mash/combined_sketch.msh",
        mash_distances=f"{TEMP}/2b_mash/mash_distances.txt",
    container:
        config["CONTAINER_MASH"]
    shell:
        "mash sketch -o {output.mash_sketch} {input} "
        "&& mash dist {output.mash_sketch} {output.mash_sketch} > {output.mash_distances}"
